########################################
# Application
########################################

NODE_ENV=production
# development | testing | production
PORT=3000

# Number of Node.js workers
# Set explicitly in production (usually = CPU cores)
# If set to 0, backend auto-detects CPU cores
WEB_CONCURRENCY=2

# When true, primary process spawns job workers alongside HTTP
RUN_WORKERS=true

########################################
# Logging
########################################

LOG_LEVEL=warn
# fatal | error | warn | info | debug | trace

########################################
# Security / JWT
########################################

# REQUIRED - generate with:
# openssl rand -base64 32
JWT_SECRET=CHANGE_ME_STRONG_SECRET

JWT_EXPIRY=7d

# Strongly recommended in production
JWT_ISSUER=authbox-ts-api
JWT_AUDIENCE=authbox-ts-client

AUTH_COOKIE_NAME=authbox_ts_session

# Must be HTTPS in production
FRONTEND_URL=https://your-frontend-domain.com
BACKEND_URL=https://api.your-domain.com

########################################
# Google OAuth
########################################

GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
# Redirect URI:
# https://api.your-domain.com/api/v1/auth/google/callback

########################################
# PostgreSQL
########################################

# Use Docker service name if running via docker-compose
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

POSTGRES_USER=authbox_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DATABASE=authbox_db

# In production, require SSL if using managed DB
POSTGRES_SSL_MODE=verify-full
# disable | allow | prefer | require | verify-ca | verify-full

DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

########################################
# Redis
########################################

# Use Docker service name
REDIS_HOST=localhost
REDIS_PORT=6379

REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

########################################
# MinIO Object Store
########################################

MINIO_ROOT_USER=authbox_admin
MINIO_ROOT_PASSWORD=authbox_password

########################################
# Hardening
########################################

# Set to true if behind a reverse proxy (NGINX, Traefik, etc.)
TRUST_PROXY=false

# Secure cookies (should be true in production)
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax